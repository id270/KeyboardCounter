<Window x:Class="KeyboardCounter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="键盘计数器"
        Width="610"
        Height="32"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent">

    <Grid>
        <!-- 横向布局 -->
        <Border x:Name="HorizontalLayout"
                CornerRadius="5"
                Background="#CC000000"
                BorderBrush="#FF444444"
                BorderThickness="1"
                Padding="6,0"
                Visibility="Visible">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">

                <!-- 天气 -->
                <emoji:TextBlock x:Name="WeatherIconH"
                                 Text="🌤"
                                 FontSize="12"
                                 VerticalAlignment="Center"
                                 Margin="0,0,2,0"/>
                <TextBlock x:Name="WeatherTempH"
                           Foreground="#87CEEB"
                           FontSize="11"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <TextBlock Text="│" Foreground="#444444" FontSize="12" Margin="0,0,4,0"/>

                <!-- Emoji -->
                <emoji:TextBlock x:Name="EmojiTextH"
                                 Text="😐"
                                 FontSize="14"
                                 VerticalAlignment="Center"
                                 Margin="0,0,4,0"/>

                <!-- 总计 -->
                <TextBlock x:Name="TotalTextH"
                           Foreground="#FF6B6B"
                           FontSize="12"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <TextBlock Text="│" Foreground="#444444" FontSize="12" Margin="0,0,4,0"/>

                <!-- 空格 -->
                <TextBlock x:Name="SpaceTextH"
                           Foreground="#4ECDC4"
                           FontSize="12"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <TextBlock Text="│" Foreground="#444444" FontSize="12" Margin="0,0,4,0"/>

                <!-- 回车 -->
                <TextBlock x:Name="EnterTextH"
                           Foreground="#FFE66D"
                           FontSize="12"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <TextBlock Text="│" Foreground="#444444" FontSize="12" Margin="0,0,4,0"/>

                <!-- 速度 -->
                <TextBlock x:Name="SpeedTextH"
                           Foreground="#A8E6CF"
                           FontSize="12"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <TextBlock Text="│" Foreground="#444444" FontSize="12" Margin="0,0,4,0"/>

                <!-- 网络 -->
                <TextBlock x:Name="NetworkTextH"
                           Foreground="#54A0FF"
                           FontSize="12"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <TextBlock Text="│" Foreground="#444444" FontSize="12" Margin="0,0,4,0"/>

                <!-- 下载总量和ISP -->
                <TextBlock x:Name="TotalDownloadTextH"
                           Foreground="#FF6B9D"
                           FontSize="12"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <TextBlock x:Name="ISPTextH"
                           Foreground="#888888"
                           FontSize="10"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 纵向布局 -->
        <Border x:Name="VerticalLayout"
                CornerRadius="5"
                Background="#CC000000"
                BorderBrush="#FF444444"
                BorderThickness="1"
                Padding="4"
                Visibility="Collapsed"
                HorizontalAlignment="Stretch">

            <StackPanel Orientation="Vertical"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch">

                <!-- 天气 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,2">
                    <emoji:TextBlock x:Name="WeatherIconV" Text="🌤" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="WeatherTempV" Foreground="#87CEEB" FontSize="11" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Emoji -->
                <emoji:TextBlock x:Name="EmojiTextV" Text="😐" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,2"/>

                <!-- 总计 -->
                <TextBlock x:Name="TotalTextV" Foreground="#FF6B6B" FontSize="11" FontFamily="Microsoft YaHei UI" HorizontalAlignment="Center" Margin="0,0,0,2"/>

                <!-- 空格（单独一行） -->
                <TextBlock x:Name="SpaceTextV" Foreground="#4ECDC4" FontSize="11" FontFamily="Microsoft YaHei UI" HorizontalAlignment="Center" Margin="0,0,0,2"/>

                <!-- 回车（单独一行） -->
                <TextBlock x:Name="EnterTextV" Foreground="#FFE66D" FontSize="11" FontFamily="Microsoft YaHei UI" HorizontalAlignment="Center" Margin="0,0,0,2"/>

                <!-- 速度 -->
                <TextBlock x:Name="SpeedTextV" Foreground="#A8E6CF" FontSize="11" FontFamily="Microsoft YaHei UI" HorizontalAlignment="Center" Margin="0,0,0,2"/>

                <!-- 网络 -->
                <TextBlock x:Name="NetworkTextV" Foreground="#54A0FF" FontSize="11" FontFamily="Microsoft YaHei UI" HorizontalAlignment="Center" Margin="0,0,0,2"/>

                <!-- 下载总量 -->
                <TextBlock x:Name="TotalDownloadTextV" Foreground="#FF6B9D" FontSize="11" FontFamily="Microsoft YaHei UI" HorizontalAlignment="Center" Margin="0,0,0,2"/>

                <!-- ISP -->
                <TextBlock x:Name="ISPTextV"
                           Foreground="#888888"
                           FontSize="11"
                           FontFamily="Microsoft YaHei UI"
                           HorizontalAlignment="Center"
                           TextWrapping="NoWrap"
                           TextTrimming="None"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
